# Build configuration
[build]
builder = "NIXPACKS"
buildCommand = "npm run build"

# Deployment configuration
[deploy]
startCommand = "npm start"
healthcheckPath = "/api/health"
healthcheckTimeout = 100

# Web service configuration
[[services]]
name = "web"
envs = { NODE_ENV = "production" }

# Port configuration for the web service
[[services.ports]]
handlers = ["http"]
port = "3000"

# Environment-specific configurations
[environments]
  # Production environment
  [environments.production]
  envs = { DATABASE_URL = "${{ Prod.DATABASE_URL }}", API_KEY = "${{ Prod.API_KEY }}" }
  
  # Development environment
  [environments.development]
  envs = { DATABASE_URL = "${{ Dev.DATABASE_URL }}", API_KEY = "${{ Dev.API_KEY }}" }
  
  # Staging environment (optional)
  [environments.staging]
  envs = { DATABASE_URL = "${{ Staging.DATABASE_URL }}", API_KEY = "${{ Staging.API_KEY }}" }

# Scaling configuration
[scaling]
min = 1
max = 5

# Custom domain configuration
[domains]
custom = "civilengineering.yourdomain.com"

# Automatic deployments configuration
[deploy.auto]
enabled = true
branch = "main"

